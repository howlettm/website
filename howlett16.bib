	shorttitle = {The {Canadian} biotechnology regulatory regime},
	url = {http://www.sciencedirect.com.proxy.lib.sfu.ca/science/article/B6V80-51F1SHV-1/2/b909077ac7e8653268592fc458e79e5c},
	doi = {10.1016/j.techsoc.2010.10.004},
	abstract = {In this article, we ask the question: how important is the participation element in the creation and reproduction of the Canadian biotechnology policy regime? We find that within the quasi-promotional regime currently in place in Canada, participation plays an interesting role (close to Hirschman's [`]voice' option), but not a core one in setting or modifying policy structure. It depends largely on the institutional setting within which the policy regime was originally constituted. We expect that in Canada, participation will make few inroads in changing the policy regime unless some core elements of the latter change.},
