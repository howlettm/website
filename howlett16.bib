@article{leong_controversial_2011,
	title = {Controversial {Science}-{Based} {Technology} {Public} {Attitude} {Formation} and {Regulation} in {Comparative} {Perspective}: {The} state {Construction} of {Policy} {Alternatives} in {Asia}},
	volume = {33},
	issn = {0160-791X},
	shorttitle = {Controversial science-based technology public attitude formation and regulation in comparative perspective},
	url = {http://www.sciencedirect.com/science/article/B6V80-52NC4TD-1/2/b195418bd24b4aeb2cd8ce4684ef22b0},
	doi = {10.1016/j.techsoc.2011.03.007},
	abstract = {{\textless}p{\textgreater}{\textless}br/{\textgreater}Past studies of the success of regulation and other forms of state and private sector activity in areas of new technologies have argued these are dependent on a number of factors, one of which is the reaction of public opinion to the innovation concerned. Most existing theories of public acceptance of controversial science-based products are based largely on European and North American case studies and are divided between those which focus on public and consumer knowledge of the science involved - the [`]deficit model' - and those which stress either the need for trust in regulatory and private sector actors involved in new product development and regulation, or the significance of individual cultural norms on attitude formation. This paper examines two cases of the introduction of controversial science in Asia - wastewater recycling in Singapore and nanotechnology regulation in China in order to assess the influence of these factors in each case. Based on this comparative research, it is argued that models of public acceptance of controversial science-based products must also take into account the state's ability to define the range of public debate as a key overall parameter of public attitude formation.{\textless}/p{\textgreater}},
	urldate = {2011-04-24},
	journal = {Technology in Society},
	author = {Leong, Ching Ching and Jarvis, Darryl and Howlett, Michael and Migone, Andrea},
	year = {2011},
	pages = {128--136},
	file = {TIS707.pdf:files/55564/TIS707.pdf:application/pdf}
}

